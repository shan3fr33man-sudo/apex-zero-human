# ─────────────────────────────────────────────────────────────────────────────
# APEX — Production Environment Variables
# Copy this file to apps/web/.env.local AND apps/orchestrator/.env
# Fill in every value. Never commit real keys to git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ────────────────────────────────────────────────────────────────
# Your Supabase project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase anon/public key (Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — NEVER prefix with NEXT_PUBLIC_ (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Used by deploy script for migrations and type generation
SUPABASE_PROJECT_ID=your-project-id-here

# Direct Postgres connection string (Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# Used by orchestrator only (same URL, no NEXT_PUBLIC_ prefix)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# ─── Anthropic (Claude API) ─────────────────────────────────────────────────
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# ─── Firecrawl (Web Scraping) ───────────────────────────────────────────────
# Get from https://firecrawl.dev/app/api-keys
FIRECRAWL_API_KEY=fc-your-key-here

# ─── Email (Resend) ─────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_your-key-here

# Email address for budget/stall alerts (orchestrator only)
ALERT_EMAIL_TO=your-email@company.com

# ─── Stripe (Payments — optional) ───────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-key-here

# ─── App Config ──────────────────────────────────────────────────────────────
# Public URL of the APEX dashboard (used for OAuth redirects, email links)
NEXT_PUBLIC_APP_URL=https://apex.yourdomain.com

# ─── SEE (Self-Evolution Engine — orchestrator only) ─────────────────────────
# Max USD budget per shadow test run
SEE_MAX_BUDGET_PER_TEST_USD=10

# Deployment window (UTC hours) — SEE only deploys during this window
SEE_DEPLOYMENT_WINDOW_START=2
SEE_DEPLOYMENT_WINDOW_END=4

# Shadow Supabase project for testing (separate from production)
SEE_SHADOW_SUPABASE_URL=https://YOUR_SHADOW_PROJECT.supabase.co
SEE_SHADOW_SUPABASE_KEY=your-shadow-service-role-key

# ─── RingCentral (Moving company vertical — optional) ───────────────────────
# RINGCENTRAL_CLIENT_ID=your-client-id
# RINGCENTRAL_CLIENT_SECRET=your-client-secret
# RINGCENTRAL_SERVER_URL=https://platform.ringcentral.com

# ─── SmartMoving CRM (Moving company vertical — optional) ───────────────────
# SMARTMOVING_API_KEY=your-api-key
# SMARTMOVING_BASE_URL=https://api.smartmoving.com
